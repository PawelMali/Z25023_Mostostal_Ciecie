<UserControl x:Class="Z25023_Mostostal_Cięcie.UI.DetailVisualizerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Z25023_Mostostal_Cięcie.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Zoom Detalu:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <Slider x:Name="ZoomSlider" Minimum="0.2" Maximum="5.0" Value="1.0" Width="250" 
                        VerticalAlignment="Center" TickFrequency="0.2" IsSnapToTickEnabled="True" 
                        ValueChanged="ZoomSlider_ValueChanged"/>
                <TextBlock Text="{Binding Value, ElementName=ZoomSlider, StringFormat=\{0:F1\}x}" 
                           VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold" Foreground="#005A9E"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#E9ECEF">
            <Canvas x:Name="DrawingCanvas" Height="500" Background="White" Margin="20" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Canvas.LayoutTransform>
                    <ScaleTransform x:Name="CanvasScale" ScaleX="1.0" ScaleY="1.0" />
                </Canvas.LayoutTransform>
            </Canvas>
        </ScrollViewer>
    </Grid>
</UserControl>
