<Window x:Class="Z25023_Mostostal_Cięcie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Z25023_Mostostal_Cięcie"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Symulator Prasy Wykrawającej - Hybrid Multistep" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen">
    
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Margin="10" Padding="15" 
                BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Parametry Detalu" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#333"/>

                <TextBlock Text="Długość (L) [mm]:" Margin="0,0,0,5"/>
                <TextBox Name="txtLength" Text="993.0" Margin="0,0,0,10" Padding="4"/>

                <TextBlock Text="Skok (P) [mm]:" Margin="0,0,0,5"/>
                <ComboBox Name="cmbPitch" Margin="0,0,0,10" Padding="4">
                    <ComboBoxItem Content="11.1" />
                    <ComboBoxItem Content="22.2" />
                    <ComboBoxItem Content="33.3" IsSelected="True" />
                    <ComboBoxItem Content="44.4" />
                    <ComboBoxItem Content="55.5" />
                    <ComboBoxItem Content="66.6" />
                    <ComboBoxItem Content="77.7" />
                    <ComboBoxItem Content="88.8" />
                    <ComboBoxItem Content="99.9" />
                </ComboBox>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Margines L:" Margin="0,0,0,5"/>
                        <TextBox Name="txtMarginLeft" Text="29.55" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Margines P:" Margin="0,0,0,5"/>
                        <TextBox Name="txtMarginRight" Text="29.55" Padding="4"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,10,0,15"/>

                <TextBlock Text="Zakres Cięcia Nożyc" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#333"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Min [mm]:" Margin="0,0,0,5"/>
                        <TextBox Name="txtShearMin" Text="1850.7" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Max [mm]:" Margin="0,0,0,5"/>
                        <TextBox Name="txtShearMax" Text="2650.7" Padding="4"/>
                    </StackPanel>
                </Grid>

                <Button Name="RunSimulationButton" Content="URUCHOM SYMULACJĘ" Height="40" 
                        Background="#007ACC" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"
                        Click="RunSimulationButton_Click"/>


            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#E1F0FA" BorderBrush="#B6D4EA" BorderThickness="1" 
                    CornerRadius="5" Padding="10" Margin="0,0,0,10">
                <TextBlock Name="SummaryTextBlock" FontSize="14" Foreground="#004A7F">
                    <Run Text="Brak wyników." FontWeight="Bold"/> 
                    <Run Text=" Uruchom symulację, aby zobaczyć podsumowanie: Ilość otworów, Wartości marginesów, Zakres perforacji."/>
                </TextBlock>
            </Border>

            <TabControl Grid.Row="1" Background="White" BorderBrush="#DDDDDD">

                <TabItem Header="Terminal Wyników (Tabela)">
                    <DataGrid Name="ResultsDataGrid" AutoGenerateColumns="False" 
                              IsReadOnly="True" HeadersVisibility="Column" 
                              GridLinesVisibility="Horizontal" AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="KROK" Binding="{Binding StepNumber}" Width="60"/>

                            <DataGridTextColumn Header="PRZESUW Δ (mm)" Binding="{Binding StepDisplacement, StringFormat={}{0:F2}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="ABS X (mm)" Binding="{Binding Delta, StringFormat={}{0:F2}}" Width="100" Foreground="Gray"/>

                            <DataGridTextColumn Header="OŚ NOŻA (mm)" Binding="{Binding CutTargetX, StringFormat={}{0:F2}}" Width="120" Foreground="Magenta"/>

                            <DataGridCheckBoxColumn Header="CIĘCIE" Binding="{Binding IsCutActive}" Width="70"/>

                            <DataGridTextColumn Header="STEMPLE (MASK)" Binding="{Binding PunchesMask}" Width="150"/>
                            <DataGridTextColumn Header="INFO" Binding="{Binding Info}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Wizualizacja Kaskadowy">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#F0F0F0">
                        <ItemsControl Name="VisualizationItemsControl" Margin="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
